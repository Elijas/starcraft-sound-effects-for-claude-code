{
  "version": "2.0",
  "description": "Comprehensive sound mapping system for Claude Code responses",
  "dimensions": {
    "mode": {
      "description": "How Claude is engaging with the user",
      "values": {
        "question": "Asking user for input, decisions, clarifications - needs attention!",
        "action": "Actively executing work, doing tasks, in progress",
        "report": "Informing, explaining, reporting results"
      }
    },
    "type": {
      "description": "What kind of work is being done",
      "values": {
        "constructive": "Building, creating, fixing, implementing, adding code",
        "destructive": "Deleting, removing, cleaning up, destroying code",
        "analytical": "Reading, searching, exploring, understanding code"
      }
    },
    "outcome": {
      "description": "How things are going",
      "values": {
        "success": "Positive, went well, completed successfully, found",
        "problem": "Error, failure, blocked, not found, issue",
        "neutral": "Normal operation, in-progress, informational"
      }
    }
  },
  "mappings": [
    {
      "mode": "question",
      "type": "constructive",
      "outcome": "success",
      "sounds": ["tadUpd02-research-complete.wav", "tadUPD06-upgrade-complete.wav"],
      "examples": [
        "Feature complete! Want me to add tests too?",
        "Implementation ready! Should I deploy?",
        "Bug fixed! Create a PR?"
      ]
    },
    {
      "mode": "question",
      "type": "constructive",
      "outcome": "problem",
      "sounds": ["tadUpd01-your-forces-are-under-attack.wav", "tadErr01-insufficient-vespene-gas.wav"],
      "examples": [
        "Build failed - how should I fix it?",
        "Missing dependencies - should I install them?",
        "Error in 3 files - which one should I tackle first?"
      ]
    },
    {
      "mode": "question",
      "type": "constructive",
      "outcome": "neutral",
      "sounds": ["tadUpd00-base-is-under-attack.wav", "tadUpd03-addon-complete.wav"],
      "examples": [
        "Important: Which architecture should I use?",
        "How should I implement this feature?",
        "Which library do you prefer?"
      ],
      "notes": "Uses 'base-is-under-attack' for urgent/important questions, 'addon-complete' for minor ones"
    },
    {
      "mode": "question",
      "type": "destructive",
      "outcome": "success",
      "sounds": ["tadUPD05-abandoning-auxiliary-structure.wav", "tadUpd03-addon-complete.wav"],
      "examples": [
        "Cleanup complete! Delete these old backups too?",
        "Removed test files successfully - remove logs as well?",
        "Old code deleted - want me to clean up comments?"
      ]
    },
    {
      "mode": "question",
      "type": "destructive",
      "outcome": "problem",
      "sounds": ["tadUpd01-your-forces-are-under-attack.wav", "tadErr04-unacceptable-landing-zone.wav"],
      "examples": [
        "Can't delete - file is locked. Force deletion?",
        "Dependencies exist - remove them too?",
        "Files in use - should I wait and retry?"
      ]
    },
    {
      "mode": "question",
      "type": "destructive",
      "outcome": "neutral",
      "sounds": ["tadUpd03-addon-complete.wav", "tadUPD05-abandoning-auxiliary-structure.wav"],
      "examples": [
        "Should I remove this deprecated code?",
        "Delete these unused imports?",
        "Clean up this old function?"
      ]
    },
    {
      "mode": "question",
      "type": "analytical",
      "outcome": "success",
      "sounds": ["tadUpd02-research-complete.wav"],
      "examples": [
        "Found exactly what you need! Want to see details?",
        "Search successful - explore the 15 results?",
        "Located the bug! Should I fix it now?"
      ]
    },
    {
      "mode": "question",
      "type": "analytical",
      "outcome": "problem",
      "sounds": ["tadErr00-not-enough-minerals.wav", "TAdErr06-not-enough-energy.wav"],
      "examples": [
        "Can't find the file - should I search elsewhere?",
        "Search returned nothing - try different terms?",
        "Pattern not found - broaden the search?"
      ]
    },
    {
      "mode": "question",
      "type": "analytical",
      "outcome": "neutral",
      "sounds": ["tadUpd03-addon-complete.wav"],
      "examples": [
        "What should I search for?",
        "Which files should I examine?",
        "What pattern are you looking for?"
      ]
    },
    {
      "mode": "action",
      "type": "constructive",
      "outcome": "success",
      "sounds": ["TAdUpd07-nuclear-missile-ready.wav", "tadUPD06-upgrade-complete.wav", "tadUpd02-research-complete.wav"],
      "examples": [
        "DEPLOYING TO PRODUCTION!",
        "All tests passing! Build successful!",
        "Feature implementation complete!",
        "Fixed all 10 bugs!"
      ],
      "notes": "Multiple sounds for variety since this is a common case"
    },
    {
      "mode": "action",
      "type": "constructive",
      "outcome": "problem",
      "sounds": ["tadUPD04-nuclear-launch-detected.wav", "tadErr01-insufficient-vespene-gas.wav", "tadErr03-landing-sequence-interrupted.wav"],
      "examples": [
        "CATASTROPHIC BUILD FAILURE!",
        "Compilation error in 15 files!",
        "Tests failing - process interrupted!",
        "Critical error during deployment!"
