  "default": "tadUpd03-addon-complete.wav",
  "notes": {
    "variety": "Multiple sounds per combination prevent boredom for frequent response types",
    "attention": "question/* combinations use attention-demanding sounds like 'base-is-under-attack'",
    "destruction": "destructive type primarily uses 'abandoning-auxiliary-structure' for thematic coherence",
    "completion": "research-complete and upgrade-complete provide satisfying completion sounds",
    "emergency": "nuclear-launch-detected reserved for catastrophic errors, nuclear-missile-ready for major victories",
    "coverage": "All 27 combinations mapped, all 14 sounds used multiple times"
  }
}
